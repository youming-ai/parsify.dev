---
import Layout from '../../layouts/BaseLayout.astro';
import { ModelComparison as ModelComparisonTool } from '../../components/tools/ai/model-comparison';
import { SEO_CONFIG } from '../../lib/seo-config';
const title = 'Model Comparison Table | Parsify.dev';
const desc = 'Filter and compare LLM models by context window, pricing, capabilities, and provider.';
---
<Layout>
  <slot name="head"><title>{title}</title><meta name="description" content={desc} /><link rel="canonical" href={`${SEO_CONFIG.BASE_URL}/ai/model-comparison`} /></slot>
  <main id="main-content" class="container mx-auto max-w-7xl px-6 py-8 lg:px-8"><ModelComparisonTool client:load /></main>
</Layout>
