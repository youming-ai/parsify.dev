---
import Layout from '../../layouts/BaseLayout.astro';
import { PromptFormatConverter as PromptFormatConverterTool } from '../../components/tools/ai/prompt-format-converter';
import { SEO_CONFIG } from '../../lib/seo-config';
const title = 'Prompt Format Converter | Parsify.dev';
const desc = 'Convert prompts between OpenAI, Anthropic, and Gemini payloads via Parsify IR.';
---
<Layout>
  <slot name="head"><title>{title}</title><meta name="description" content={desc} /><link rel="canonical" href={`${SEO_CONFIG.BASE_URL}/ai/prompt-format-converter`} /></slot>
  <main id="main-content" class="container mx-auto max-w-7xl px-6 py-8 lg:px-8"><PromptFormatConverterTool client:load /></main>
</Layout>
