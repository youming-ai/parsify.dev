---
import Layout from '../../layouts/BaseLayout.astro';
import { ContextVisualizer as ContextVisualizerTool } from '../../components/tools/ai/context-visualizer';
import { SEO_CONFIG } from '../../lib/seo-config';
const title = 'Context Window Visualizer | Parsify.dev';
const desc = 'Visualize how prompts, messages, and RAG context consume an LLM context window.';
---
<Layout>
  <slot name="head"><title>{title}</title><meta name="description" content={desc} /><link rel="canonical" href={`${SEO_CONFIG.BASE_URL}/ai/context-visualizer`} /></slot>
  <main id="main-content" class="container mx-auto max-w-7xl px-6 py-8 lg:px-8"><ContextVisualizerTool client:load /></main>
</Layout>
