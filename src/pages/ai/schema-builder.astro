---
import Layout from '../../layouts/BaseLayout.astro';
import { SchemaBuilder as SchemaBuilderTool } from '../../components/tools/ai/schema-builder';
import { SEO_CONFIG } from '../../lib/seo-config';
const title = 'Tool Schema Builder | Parsify.dev';
const desc = 'Build LLM tool schemas with form rows and export provider-specific tool formats.';
---
<Layout>
  <slot name="head"><title>{title}</title><meta name="description" content={desc} /><link rel="canonical" href={`${SEO_CONFIG.BASE_URL}/ai/schema-builder`} /></slot>
  <main id="main-content" class="container mx-auto max-w-7xl px-6 py-8 lg:px-8"><SchemaBuilderTool client:load /></main>
</Layout>
