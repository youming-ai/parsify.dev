---
import Layout from '../../layouts/BaseLayout.astro';
import { RateLimitCalculator as RateLimitCalculatorTool } from '../../components/tools/ai/rate-limit-calculator';
import { SEO_CONFIG } from '../../lib/seo-config';
const title = 'Rate Limit Calculator | Parsify.dev';
const desc = 'Estimate LLM API throughput limits in your browser.';
---
<Layout>
  <slot name="head"><title>{title}</title><meta name="description" content={desc} /><link rel="canonical" href={`${SEO_CONFIG.BASE_URL}/ai/rate-limit-calculator`} /></slot>
  <main id="main-content" class="container mx-auto max-w-7xl px-6 py-8 lg:px-8"><RateLimitCalculatorTool client:load /></main>
</Layout>
