---
import Layout from '../../layouts/BaseLayout.astro';
import { FewShotBuilder as FewShotBuilderTool } from '../../components/tools/ai/few-shot-builder';
import { SEO_CONFIG } from '../../lib/seo-config';
const title = 'Few-shot Builder | Parsify.dev';
const desc = 'Generate structured few-shot prompts from task descriptions and examples.';
---
<Layout>
  <slot name="head"><title>{title}</title><meta name="description" content={desc} /><link rel="canonical" href={`${SEO_CONFIG.BASE_URL}/ai/few-shot-builder`} /></slot>
  <main id="main-content" class="container mx-auto max-w-7xl px-6 py-8 lg:px-8"><FewShotBuilderTool client:load /></main>
</Layout>
