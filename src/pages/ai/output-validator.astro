---
import Layout from '../../layouts/BaseLayout.astro';
import { OutputValidator as OutputValidatorTool } from '../../components/tools/ai/output-validator';
import { SEO_CONFIG } from '../../lib/seo-config';
const title = 'Structured Output Validator | Parsify.dev';
const desc = 'Validate LLM JSON output against a schema and locate field-level errors.';
---
<Layout>
  <slot name="head"><title>{title}</title><meta name="description" content={desc} /><link rel="canonical" href={`${SEO_CONFIG.BASE_URL}/ai/output-validator`} /></slot>
  <main id="main-content" class="container mx-auto max-w-7xl px-6 py-8 lg:px-8"><OutputValidatorTool client:load /></main>
</Layout>
