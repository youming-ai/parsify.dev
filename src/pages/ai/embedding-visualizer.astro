---
import Layout from '../../layouts/BaseLayout.astro';
import { EmbeddingVisualizer as EmbeddingVisualizerTool } from '../../components/tools/ai/embedding-visualizer';
import { SEO_CONFIG } from '../../lib/seo-config';
const title = 'Embedding Similarity Visualizer | Parsify.dev';
const desc = 'Compare embedding vectors with cosine similarity, nearest neighbors, and a similarity matrix.';
---
<Layout>
  <slot name="head"><title>{title}</title><meta name="description" content={desc} /><link rel="canonical" href={`${SEO_CONFIG.BASE_URL}/ai/embedding-visualizer`} /></slot>
  <main id="main-content" class="container mx-auto max-w-7xl px-6 py-8 lg:px-8"><EmbeddingVisualizerTool client:load /></main>
</Layout>
