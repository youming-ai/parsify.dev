---
import Layout from '../../layouts/BaseLayout.astro';
import { FinetuningValidator as FinetuningValidatorTool } from '../../components/tools/ai/finetuning-validator';
import { SEO_CONFIG } from '../../lib/seo-config';
const title = 'Fine-tuning Dataset Validator | Parsify.dev';
const desc = 'Validate OpenAI-style JSONL fine-tuning datasets for format, roles, duplicates, and token size.';
---
<Layout>
  <slot name="head"><title>{title}</title><meta name="description" content={desc} /><link rel="canonical" href={`${SEO_CONFIG.BASE_URL}/ai/finetuning-validator`} /></slot>
  <main id="main-content" class="container mx-auto max-w-7xl px-6 py-8 lg:px-8"><FinetuningValidatorTool client:load /></main>
</Layout>
