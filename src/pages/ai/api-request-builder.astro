---
import Layout from '../../layouts/BaseLayout.astro';
import { ApiRequestBuilder as ApiRequestBuilderTool } from '../../components/tools/ai/api-request-builder';
import { SEO_CONFIG } from '../../lib/seo-config';
const title = 'LLM API Request Builder | Parsify.dev';
const desc = 'Build provider-specific LLM API payloads and export curl and TypeScript fetch snippets.';
---
<Layout>
  <slot name="head"><title>{title}</title><meta name="description" content={desc} /><link rel="canonical" href={`${SEO_CONFIG.BASE_URL}/ai/api-request-builder`} /></slot>
  <main id="main-content" class="container mx-auto max-w-7xl px-6 py-8 lg:px-8"><ApiRequestBuilderTool client:load /></main>
</Layout>
