---
import Layout from '../layouts/BaseLayout.astro';
import PageSEO from '../components/seo/page-seo.astro';
import { SEO_CONFIG } from '../lib/seo-config';
---

<Layout>
  <slot name="head">
    <PageSEO
      title="Page not found"
      description="The page you're looking for doesn't exist."
      path="/404"
      appendSiteName={false}
    />
  </slot>
  <main id="main-content" class="container mx-auto max-w-7xl px-6 py-24 text-center lg:px-8">
    <p class="text-sm font-medium text-primary">404</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight">Page not found</h1>
    <p class="mt-4 text-lg text-muted-foreground">The page you're looking for doesn't exist.</p>
    <a
      href="/"
      class="mt-8 inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
    >
      Back to home
    </a>
  </main>
</Layout>
