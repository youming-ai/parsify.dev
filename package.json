{
  "name": "parsify-dev",
  "version": "2.0.0",
  "private": true,
  "description": "AI & LLM Developer Tools - Privacy-first browser utilities for agent and LLM application developers.",
  "homepage": "https://parsify.dev",
  "repository": "https://github.com/youming-ai/parsify.dev",
  "author": "Youming <ikashue@gmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "srvx serve --entry ./dist/server/server.js --port 3000 --static ../client",
    "lint": "biome check ./src",
    "lint:fix": "biome check --fix ./src",
    "format": "biome format --write ./src",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf node_modules dist .output",
    "deploy": "bun run build && wrangler deploy",
    "preview": "bun run build && wrangler dev",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-router": "^1.170.4",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.19",
    "hono-pino": "^0.10.3",
    "hono-rate-limiter": "^0.5.3",
    "lucide-react": "^1.16.0",
    "pino": "^10.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cloudflare/vite-plugin": "^1.37.1",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "lefthook": "^2.1.6",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3",
    "vite": "^7.3.3",
    "wrangler": "^4.92.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.5"
}
