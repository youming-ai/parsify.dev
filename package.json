{
	"name": "@parsify/web",
	"version": "1.0.0",
	"description": "Online Developer Tools Platform",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"build:analyze": "ANALYZE=true next build",
		"build:optimize": "pnpm build && pnpm bundle:optimize",
		"build:prod": "NODE_ENV=production next build",
		"start": "next start",
		"preview": "next build && next start",
		"deploy": "vercel --prod",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"format": "biome format . --write",
		"type-check": "tsc --noEmit",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage",
		"test:e2e": "playwright test",
		"test:security": "audit-ci --moderate",
		"clean": "rm -rf node_modules .next dist",
		"bundle:init": "tsx src/monitoring/index.ts init",
		"bundle:analyze": "tsx src/monitoring/index.ts analyze",
		"bundle:optimize": "tsx src/monitoring/index.ts optimize",
		"bundle:report": "tsx src/monitoring/index.ts report",
		"bundle:budget": "tsx src/monitoring/index.ts budget",
		"bundle:dry-run": "tsx src/monitoring/index.ts optimize --dry-run",
		"bundle:full": "tsx src/monitoring/index.ts optimize --assets --enforce-budget",
		"budget": "tsx src/monitoring/budget-cli.ts",
		"budget:init": "tsx src/monitoring/budget-cli.ts init",
		"budget:status": "tsx src/monitoring/budget-cli.ts status",
		"budget:validate": "tsx src/monitoring/budget-cli.ts validate",
		"budget:build": "tsx src/monitoring/budget-cli.ts build:validate",
		"budget:ci": "tsx src/monitoring/budget-cli.ts ci:validate",
		"budget:report": "tsx src/monitoring/budget-cli.ts report:generate",
		"budget:alerts": "tsx src/monitoring/budget-cli.ts alerts:list",
		"budget:optimize": "tsx src/monitoring/budget-cli.ts optimize:recommendations",
		"budget:enforce": "tsx src/monitoring/ci-cd-integration.ts && tsx src/monitoring/budget-cli.ts validate"
	},
	"dependencies": {
		"@microsoft/clarity": "^1.0.0",
		"@monaco-editor/react": "^4.6.0",
