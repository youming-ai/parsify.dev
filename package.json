{
  "name": "parsify-dev",
  "version": "2.0.0",
  "private": true,
  "description": "Browser-local OCR powered by PaddleOCR PP-OCRv6. Images never leave your device.",
  "homepage": "https://parsify.dev",
  "repository": "https://github.com/youming-ai/parsify.dev",
  "bugs": "https://github.com/youming-ai/parsify.dev/issues",
  "keywords": [
    "ai",
    "llm",
    "url-to-markdown",
    "web-scraping",
    "content-extraction",
    "jina-reader",
    "deepseek",
    "rag",
    "markdown"
  ],
  "author": "Youming <ikashue@gmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun src/dev-server.ts & vite",
    "dev:api": "bun src/dev-server.ts",
    "dev:ui": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "bun dist/server/entry.server.js",
    "deploy": "wrangler deploy",
    "lint": "biome check ./src",
    "lint:fix": "biome check --fix ./src",
    "format": "biome format --write ./src",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf node_modules dist .output",
    "postinstall": "mkdir -p public/ort && cp node_modules/onnxruntime-web/dist/ort-wasm-simd-threaded.jsep.mjs node_modules/onnxruntime-web/dist/ort-wasm-simd-threaded.jsep.wasm node_modules/onnxruntime-web/dist/ort-wasm-simd-threaded.wasm public/ort/"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.25",
    "lucide-react": "^1.20.0",
    "onnxruntime-web": "^1.26.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@cloudflare/vite-plugin": "^1.41.0",
    "@cloudflare/workers-types": "^4.20260617.1",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "bun-types": "^1.3.14",
    "lefthook": "^2.1.9",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.5"
}
