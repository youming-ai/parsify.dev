    "hono": "^4.12.19",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tanstack/router-plugin": "^1.168.6",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
