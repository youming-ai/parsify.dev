		"next-themes": "^0.4.6",
		"pdf-lib": "^1.17.1",
		"postcss": "^8.5.0",
		"qrcode": "^1.5.3",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"sharp": "^0.34.5",
		"sonner": "^2.0.7",
		"sql-formatter": "^15.6.10",
