{
  "scripts": {
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "test:unit": "vitest run --reporter=verbose --coverage",
    "test:unit:watch": "vitest --watch",
    "test:unit:ui": "vitest --ui",
    "test:integration": "vitest run --config=vitest.integration.config.ts",
    "test:integration:watch": "vitest --config=vitest.integration.config.ts --watch",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:codegen": "playwright codegen",
    "test:performance": "playwright test tests/e2e/performance-and-accessibility.spec.ts --grep='Performance Tests'",
    "test:accessibility": "playwright test tests/e2e/performance-and-accessibility.spec.ts --grep='Accessibility Tests'",
    "test:accessibility:report": "node scripts/generate-accessibility-report.js",
    "test:cross-browser": "playwright test --config=playwright.cross-browser.config.ts",
    "test:visual": "chromatic test",
    "test:visual:ci": "chromatic test --exit-zero-on-changes",
    "test:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:security": "npm audit && node scripts/security-scan.js",
    "test:regression": "pnpm test:unit && pnpm test:e2e --grep='regression'",
    "test:mobile": "playwright test tests/e2e/mobile.spec.ts",
    "test:desktop": "playwright test tests/e2e/desktop.spec.ts",
    "test:tools": "playwright test tests/e2e/tools/",
    "test:workflows": "playwright test tests/e2e/workflows/",
    "test:load": "node scripts/load-testing.js",
    "test:bundlesize": "pnpm build && bundlesize",
    "test:typescript": "tsc --noEmit",
    "test:lint": "biome check .",
    "test:format": "biome format . --check",
    "coverage:merge": "node scripts/merge-coverage.js",
    "coverage:report": "node scripts/generate-coverage-report.js",
    "coverage:badge": "node scripts/generate-coverage-badge.js",
    "coverage:upload": "codecov",
    "test:parallel": "pnpm run-p test:unit test:integration test:e2e",
    "test:sequential": "pnpm run-s test:unit test:integration test:e2e",
    "test:ci:unit": "vitest run --reporter=junit --outputFile=junit.xml",
    "test:ci:integration": "vitest run --config=vitest.integration.config.ts --reporter=junit --outputFile=junit-integration.xml",
    "test:ci:e2e": "playwright test --reporter=junit --output-file=junit-e2e.xml",
    "test:ci:all": "pnpm run-s test:ci:unit test:ci:integration test:ci:e2e",
    "test:watch:all": "pnpm run-p test:unit:watch test:integration:watch",
    "test:ci:quality": "pnpm run-s test:typescript test:lint test:format",
    "test:pre-commit": "lint-staged",
    "test:pr": "pnpm run-s test:ci:quality test:ci:unit test:ci:integration",
    "test:staging": "playwright test --config=playwright.staging.config.ts",
    "test:production": "playwright test --config=playwright.production.config.ts",
    "test:monitoring": "node scripts/monitoring-tests.js",
    "test:uptime": "node scripts/uptime-tests.js",
    "test:real-users": "node scripts/real-user-monitoring.js",
    "test:a11y": "pa11y-ci http://localhost:3000",
    "test:a11y:report": "pa11y-ci --sitemap http://localhost:3000/sitemap.xml",
    "test:bundle": "webpack-bundle-analyzer dist/static/js/*.js",
    "test:env": "node scripts/environment-tests.js",
    "test:api": "jest tests/api/",
    "test:components": "vitest run tests/components/",
    "test:pages": "playwright test tests/pages/",
    "test:flows": "playwright test tests/flows/",
    "test:critical": "playwright test --grep='critical'",
    "test:non-critical": "playwright test --grep='non-critical'",
    "test:flaky": "vitest run --config=vitest.flaky.config.ts --retry=5",
    "test:slow": "vitest run --config=vitest.slow.config.ts --timeout=30000",
    "test:memory": "node scripts/memory-tests.js",
    "test:concurrency": "node scripts/concurrency-tests.js",
    "test:failover": "node scripts/failover-tests.js",
    "test:chaos": "node scripts/chaos-engineering.js"
  }
}
