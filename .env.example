# Parsify.dev Environment Variables
# WARNING: This project does NOT use server-side API keys.
# All AI provider calls are BYOK (Bring Your Own Key) from the browser.
# No API keys should ever be committed to this repo.

# Deployment
# NODE_ENV=production

# Required for CORS allowlist (e.g. https://parsify.dev in production)
PUBLIC_ORIGIN=http://localhost:3000

# Optional – defaults to "info". Set to "debug" for verbose output.
# LOG_LEVEL=info
