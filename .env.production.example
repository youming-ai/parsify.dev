# Production Environment Variables Example
# Copy this to .env.production for deployment

# Next.js Configuration
NEXT_PUBLIC_APP_URL=https://parsify.dev
NEXT_PUBLIC_APP_NAME=Parsify.dev
NEXT_PUBLIC_APP_DESCRIPTION=Online Developer Tools Platform

# Analytics and Monitoring
NEXT_PUBLIC_CLARITY_ID=your_clarity_id_here
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id_here

# Security Configuration
NEXT_PUBLIC_SECURITY_KEY=your_security_key_here

# Performance Optimization
NEXT_OPTIMIZE_IMAGES=true
NEXT_COMPRESS=true
NEXT_MINIMIZE=true

# CDN and Asset Configuration
NEXT_PUBLIC_CDN_URL=https://cdn.parsify.dev
NEXT_PUBLIC_ASSET_PREFIX=/assets

# Feature Flags (Production)
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_MONITORING=true
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true
NEXT_PUBLIC_ENABLE_PERFORMANCE_TRACKING=true

# Bundle Optimization
NEXT_PUBLIC_BUNDLE_ANALYZER=false
NEXT_PUBLIC_SOURCEMAPS=false

# API Configuration (if needed)
API_BASE_URL=https://api.parsify.dev
API_TIMEOUT=10000

# Cache Configuration
CACHE_MAX_AGE=31536000
CDN_CACHE_TTL=86400

# Security Headers
ENABLE_CSP=true
ENABLE_HSTS=true
ENABLE_X_FRAME_OPTIONS=true

# Performance Budget
BUNDLE_SIZE_LIMIT=250000
IMAGE_SIZE_LIMIT=500000
